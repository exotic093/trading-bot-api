# Trading Bot API - Environment Variables
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git!

# ===== Data Adapters =====

# Binance (crypto market data)
# Sign up: https://www.binance.com/en/my/settings/api-management
# Permissions: READ ONLY (disable trading & withdrawals)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Polygon.io (US equities)
# Sign up: https://polygon.io/
POLYGON_API_KEY=

# OANDA (forex)
# Sign up: https://www.oanda.com/account/login/
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# FRED (Federal Reserve Economic Data)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Trading Economics
# Sign up: https://tradingeconomics.com/api
TRADINGECONOMICS_API_KEY=

# Finnhub (stock data)
# Sign up: https://finnhub.io/register
FINNHUB_API_KEY=

# ===== Telegram Bot =====
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Application Settings =====
PORT=8080
LOG_LEVEL=INFO
